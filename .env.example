# Tenalet API base URL (backend endpoint)
TENALET_API_URL=https://api.tenalet.com

# Tenalet App URL (where embed.js is served from)
TENALET_APP_URL=https://app.tenalet.com

# Your partner API key (from Tenalet admin dashboard)
TENALET_API_KEY=tnlt_pk_your_key_here

# Webhook secret (must match what's configured for your partner account)
TENALET_WEBHOOK_SECRET=

# Port for the demo server
PORT=3500
